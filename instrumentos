<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fuel Flow Gauge</title>

<style>
body{
    margin:0;
    background:#202020;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
}

canvas{
    background:#111;
    border-radius:10px;
}
</style>
</head>

<body>

<canvas id="gauge" width="600" height="600"></canvas>

<script>

const canvas=document.getElementById("gauge");
const ctx=canvas.getContext("2d");

const cx=300;
const cy=300;
const r=220;

let valor=0;
let subir=true;

function dibujar(){

    ctx.clearRect(0,0,600,600);

    // Fondo
    ctx.fillStyle="#111";
    ctx.fillRect(0,0,600,600);

    // Círculo
    ctx.beginPath();
    ctx.arc(cx,cy,r,0,Math.PI*2);
    ctx.fillStyle="#181818";
    ctx.fill();

    // Marcas
    for(let i=0;i<=60;i++){

        let ang=(-135+i*4.5)*Math.PI/180;

        let r1=r-10;
        let r2=r-35;

        if(i%10==0){
            r2=r-55;
            ctx.lineWidth=5;
        }else{
            ctx.lineWidth=2;
        }

        ctx.strokeStyle="white";

        ctx.beginPath();
        ctx.moveTo(
            cx+Math.cos(ang)*r1,
            cy+Math.sin(ang)*r1
        );

        ctx.lineTo(
            cx+Math.cos(ang)*r2,
            cy+Math.sin(ang)*r2
        );

        ctx.stroke();

        if(i%10==0){

            ctx.fillStyle="white";
            ctx.font="30px Arial";
            ctx.textAlign="center";
            ctx.textBaseline="middle";

            let tx=cx+Math.cos(ang)*(r-90);
            let ty=cy+Math.sin(ang)*(r-90);

            ctx.fillText(i,tx,ty);

        }

    }

    // Texto
    ctx.fillStyle="white";
    ctx.font="28px Arial";
    ctx.textAlign="center";

    ctx.fillText("GPH",cx,170);
    ctx.fillText("FUEL",cx,360);
    ctx.fillText("FLOW",cx,395);

    // Aguja
    let ang=(-135+valor*4.5)*Math.PI/180;

    ctx.save();

    ctx.translate(cx,cy);
    ctx.rotate(ang);

    ctx.strokeStyle="white";
    ctx.lineWidth=6;

    ctx.beginPath();
    ctx.moveTo(0,20);
    ctx.lineTo(0,-170);
    ctx.stroke();

    ctx.restore();

    // Centro
    ctx.beginPath();
    ctx.arc(cx,cy,10,0,Math.PI*2);
    ctx.fillStyle="#666";
    ctx.fill();

}

function animar(){

    if(subir){
        valor+=0.2;
        if(valor>=60) subir=false;
    }else{
        valor-=0.2;
        if(valor<=0) subir=true;
    }

    dibujar();

    requestAnimationFrame(animar);

}

dibujar();
animar();

</script>

</body>
</html>
